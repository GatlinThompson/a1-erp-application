enum ProductType {
  HARDWARE
  PART
  KIT
  SUB_PART
  SHIPPING_KIT
  MATERIAL
  HARDWARE_KIT
  @@schema("public")
}

model Product {
  id        Int         @id @default(autoincrement())
  name      String?      
  sku       String      @unique
  quantity_on_hand  Int         @default(0)
  reorder_point      Int         @default(0)
  price     Float  @default(0.00)
  location  String? @default("A1")
  type      ProductType
  archived  Boolean     @default(false)
  allocated_quantity Int         @default(0)
  hardwares  ProductHardware[]     @relation("ProductHardwares")
  usedInHardwares ProductHardware[] @relation("HardwareUsedIn")
  parts      ProductPart[]        @relation("ProductParts")
  usedInParts ProductPart[]       @relation("PartUsedIn")
  hardware_kits ProductHardwareKit[] @relation("ProductHardwareKits")
  usedInHardwareKits ProductHardwareKit[] @relation("HardwareKitUsedIn")
  materials  ProductMaterial[]     @relation("ProductMaterials")
  usedInMaterials ProductMaterial[] @relation("MaterialUsedIn")
  processes  ProductProcess[]      @relation("ProductProcesses")
  @@schema("public")
}

model ProductHardware {
  id        Int     @id @default(autoincrement())
  product   Product @relation("ProductHardwares", fields: [productId], references: [id])
  productId Int
  hardware  Product @relation("HardwareUsedIn", fields: [hardwareId], references: [id])
  hardwareId Int
  quantity  Int     @default(1)
  @@unique([productId, hardwareId])
  @@schema("public")
}

model ProductPart {
  id        Int     @id @default(autoincrement())
  product   Product @relation("ProductParts", fields: [productId], references: [id])
  productId Int
  part      Product @relation("PartUsedIn", fields: [partId], references: [id])
  partId    Int
  quantity  Int     @default(1)
  @@unique([productId, partId])
  @@schema("public")
}

model ProductHardwareKit {
  id        Int     @id @default(autoincrement())
  product   Product @relation("ProductHardwareKits", fields: [productId], references: [id])
  productId Int
  kit       Product @relation("HardwareKitUsedIn", fields: [kitId], references: [id])
  kitId     Int
  quantity  Int     @default(1)
  @@unique([productId, kitId])
  @@schema("public")
}

model ProductMaterial {
  id        Int     @id @default(autoincrement())
  product   Product @relation("ProductMaterials", fields: [productId], references: [id])
  productId Int
  material  Product @relation("MaterialUsedIn", fields: [materialId], references: [id])
  materialId Int
  quantity  Int     @default(1) // Quantity of material required for the product fix for specific dim
  @@unique([productId, materialId])
  @@schema("public")
}

model ProductProcess {
  id        Int     @id @default(autoincrement())
  product   Product @relation("ProductProcesses", fields: [productId], references: [id])
  productId Int
  process   Process @relation("ProductProcesses", fields: [processId], references: [id])
  processId Int
  process_sequence  Int     @default(1) // Sequence of the process in the product's manufacturing workflow
  @@unique([productId, processId])
  @@schema("public")
}

model Process {
  id        Int     @id @default(autoincrement())
  process_name      String
  products  ProductProcess[] @relation("ProductProcesses")
  @@schema("public")
}